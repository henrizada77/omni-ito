# Copie para .env e preencha com os valores do seu projeto Supabase
# (Dashboard → Project Settings → API).
#
# Estas chaves são PUBLICÁVEIS: elas vão para o bundle e ficam visíveis no
# navegador — é o desenho do Supabase. Quem protege os dados é o RLS, não elas.
# NUNCA coloque aqui a service_role key: ela ignora RLS por definição e só pode
# existir como secret da Edge Function (Deno.env.get).

VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
